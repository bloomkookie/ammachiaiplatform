# ─────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env and fill in
# ─────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS / CSRF (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost,https://your-domain.com

# API Keys
GEMINI_API_KEY=
OPENWEATHER_API_KEY=
PLANT_ID_KEY=
MARKET_API_KEY=
